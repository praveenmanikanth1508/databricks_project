{
  "datasets": [
    {
      "name": "db5b93d0",
      "displayName": "EarthQuake_detail",
      "queryLines": [
        "select * from dev_catalog.silver.earthquake_data_final"
      ],
      "catalog": "dev_catalog",
      "schema": "silver"
    },
    {
      "name": "dff0fcb9",
      "displayName": "EarthQuake_data_type",
      "queryLines": [
        "select count(*) as total_magnitude_bucket,\r\n",
        "        magnitude_bucket from (select CASE\r\n",
        "          WHEN mag < 2 THEN 'Micro (<2)'\r\n",
        "          WHEN mag BETWEEN 2 AND 3 THEN 'Minor (2–3)'\r\n",
        "          WHEN mag BETWEEN 3 AND 4 THEN 'Light (3–4)'\r\n",
        "          ELSE 'Moderate+ (4+)'\r\n",
        "        END AS magnitude_bucket\r\n",
        "        from silver.earthquake_data_final )\r\n",
        "        group by magnitude_bucket"
      ],
      "catalog": "dev_catalog",
      "schema": "silver"
    },
    {
      "name": "8a2233c3",
      "displayName": "EartQuake_place",
      "queryLines": [
        "SELECT  count(*) AS event_count,\r\n",
        "          CASE WHEN size(split(place, ', ')) = 1 THEN split(place, ', ')[0]\r\n",
        "            ELSE split(place, ', ')[1]\r\n",
        "          END AS country\r\n",
        "          --split(place, ', ')[1] as country\r\n",
        "        FROM (\r\n",
        "          SELECT\r\n",
        "             time,\r\n",
        "            title,\r\n",
        "            mag,\r\n",
        "            longitude,\r\n",
        "            place,\r\n",
        "            latitude\r\n",
        "          FROM dev_catalog.silver.earthquake_data_final\r\n",
        "        )\r\n",
        "        GROUP BY country"
      ],
      "catalog": "dev_catalog",
      "schema": "silver"
    }
  ],
